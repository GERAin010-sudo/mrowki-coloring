# ==============================================
# Mrówki Coloring CRM — environment variables
# Copy this file to .env and fill in real values.
# ==============================================

# ── Telegram bot (optional) ──
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE
ADMIN_TELEGRAM_IDS=

# ── Server ──
PORT=3000

# ── Production security ──
# NODE_ENV=production
# COOKIE_SECURE=1                # Secure cookies (HTTPS only)

# ── Public site integration ──
# If CRM is accessed from a static site on a different domain:
# SITE_ORIGIN=https://mrowki-coloring.pl

# ── Uploads dir (optional; default: ./uploads) ──
# UPLOADS_DIR=/var/lib/mrowki-crm/uploads

# ── Other ──
GOOGLE_MAPS_API_KEY=
COMPANY_PHONE=+48 794 149 921
COMPANY_EMAIL=kontakt@mrowki-coloring.pl

# ── DEV ONLY: disable login (DO NOT use in production) ──
# AUTH_DISABLED=1
